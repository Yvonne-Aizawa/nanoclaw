{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NanoClaw config.json",
  "type": "object",
  "required": ["ai"],
  "properties": {
    "ai": {
      "type": "object",
      "required": ["type", "api", "oauth", "token"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["api", "oauth", "token"],
          "description": "Which AI endpoint to use"
        },
        "api": { "$ref": "#/$defs/aiEndpoint" },
        "oauth": { "$ref": "#/$defs/aiEndpoint" },
        "token": { "$ref": "#/$defs/aiEndpoint" }
      }
    },
    "telegram": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "main_bot_token": { "type": "string" },
        "bot_swarm_tokens": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "tools": {
      "type": "object",
      "additionalProperties": false,
      "description": "Tool integrations available to agents",
      "properties": {
        "brave": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "token": { "type": "string" },
            "groups": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Restrict brave search to these groups. Omit to allow all groups."
            }
          }
        },
        "caldav": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "url": { "type": "string" },
            "username": { "type": "string" },
            "password": { "type": "string" },
            "groups": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Restrict CalDAV to these groups. Omit to allow all groups."
            }
          }
        },
        "browser": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Start a Playwright MCP container for browser automation"
            },
            "port": {
              "type": "integer",
              "minimum": 1024,
              "maximum": 65535,
              "description": "Host port for the Playwright MCP container. Defaults to 7703."
            },
            "memory": {
              "type": "string",
              "description": "Memory limit. Defaults to \"1g\"."
            }
          }
        },
        "ollama": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable local Ollama model access for agents"
            },
            "groups": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Restrict Ollama to these groups. Omit to allow all groups."
            }
          }
        }
      }
    },
    "mcp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "servers": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/mcpNpxServer" },
              { "$ref": "#/$defs/mcpUvxServer" },
              { "$ref": "#/$defs/mcpRemoteServer" }
            ]
          }
        }
      }
    },
    "vision": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Set false to disable image/vision for models that don't support it"
        }
      }
    },
    "openclawcity": {
      "type": "object",
      "additionalProperties": false,
      "description": "OpenClawCity channel.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Set false to disable the channel. Defaults to true."
        },
        "token": {
          "type": "string",
          "description": "Bot JWT token. Alternatively set OPENCLAWCITY_BOT_TOKEN in .env."
        },
        "apiUrl": {
          "type": "string",
          "description": "API base URL. Defaults to https://api.openbotcity.com."
        }
      }
    },
    "containers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "registry": {
          "type": "string",
          "description": "Registry prefix for pulling images on startup. Example: \"ghcr.io/yourname\""
        }
      }
    },
    "group": {
      "type": "object",
      "description": "Per-group overrides, keyed by group folder name",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "heartbeat": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "intervalMs": {
                "type": "integer",
                "minimum": 60000,
                "description": "Override the global heartbeat interval for this group (ms)"
              }
            }
          },
          "service": {
            "type": "object",
            "additionalProperties": false,
            "description": "Persistent outbound service container for this group (e.g. WebSocket client)",
            "required": ["enabled"],
            "properties": {
              "enabled": {
                "type": "boolean",
                "description": "Set true to start the service container on launch"
              },
              "image": {
                "type": "string",
                "description": "Docker image to use. Defaults to node:20-alpine"
              },
              "memory": {
                "type": "string",
                "description": "Memory limit, e.g. \"256m\" or \"1g\". Defaults to \"256m\""
              },
              "cpus": {
                "type": "number",
                "exclusiveMinimum": 0,
                "description": "CPU limit (fractional cores). Defaults to 0.5"
              }
            }
          },
          "mcp": {
            "type": "object",
            "additionalProperties": false,
            "description": "MCP server restrictions for this group",
            "required": ["allowlist"],
            "properties": {
              "allowlist": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Explicit list of MCP server names this group may access. Omit to allow all."
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "aiEndpoint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "endpoint": {
          "type": "string",
          "description": "Custom API endpoint URL"
        },
        "key": { "type": "string" },
        "model": {
          "type": "string",
          "description": "Default model ID override (used when chatModel/cronModel are not set)"
        },
        "chatModel": {
          "type": "string",
          "description": "Model for chat messages and heartbeat runs. Falls back to model."
        },
        "cronModel": {
          "type": "string",
          "description": "Model for scheduled cron tasks created by agents. Falls back to model."
        }
      }
    },
    "mcpResourceLimits": {
      "type": "object",
      "properties": {
        "cpus": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "CPU limit in fractional cores. Defaults to 1."
        },
        "memory": {
          "type": "string",
          "pattern": "^[0-9]+(b|k|m|g|kb|mb|gb)$",
          "description": "Memory limit e.g. \"256m\", \"1g\". Defaults to \"512m\"."
        },
        "mounts": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[^:]+:[^:]+(:(ro|rw))?$",
            "description": "hostPath:containerPath or hostPath:containerPath:ro"
          },
          "description": "Host paths to mount into the MCP container"
        },
        "groups": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Restrict this server to specific agent groups (folder names). Omit to allow all groups."
        }
      }
    },
    "mcpNpxServer": {
      "allOf": [{ "$ref": "#/$defs/mcpResourceLimits" }],
      "type": "object",
      "required": ["name", "type", "package", "port"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique container name suffix"
        },
        "type": { "type": "string", "const": "npx" },
        "package": {
          "type": "string",
          "description": "npm package to run via npx"
        },
        "port": { "type": "integer", "minimum": 1024, "maximum": 65535 },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "args": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Extra CLI arguments passed to the subprocess after the package name"
        },
        "mounts": true,
        "cpus": true,
        "memory": true,
        "groups": true
      }
    },
    "mcpUvxServer": {
      "allOf": [{ "$ref": "#/$defs/mcpResourceLimits" }],
      "type": "object",
      "required": ["name", "type", "package", "port"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique container name suffix"
        },
        "type": { "type": "string", "const": "uvx" },
        "package": {
          "type": "string",
          "description": "Python package to run via uvx"
        },
        "port": { "type": "integer", "minimum": 1024, "maximum": 65535 },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "args": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Extra CLI arguments passed to the subprocess after the package name"
        },
        "mounts": true,
        "cpus": true,
        "memory": true,
        "groups": true
      }
    },
    "mcpRemoteServer": {
      "allOf": [{ "$ref": "#/$defs/mcpResourceLimits" }],
      "type": "object",
      "required": ["name", "type", "url", "port"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique container name suffix"
        },
        "type": { "type": "string", "const": "remote" },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Upstream MCP server URL"
        },
        "port": { "type": "integer", "minimum": 1024, "maximum": 65535 },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "HTTP headers injected into every upstream request (stay in proxy container)"
        },
        "mounts": true,
        "cpus": true,
        "memory": true,
        "groups": true
      }
    }
  }
}
